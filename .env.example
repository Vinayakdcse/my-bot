# ──────────────────────────────────────────────
#  .env  —  Copy this file and fill in your keys
#  NEVER commit this file to git!
# ──────────────────────────────────────────────

# ── Telegram ───────────────────────────────────
# Create a bot at https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUVwxyz

# Your Telegram chat ID.
# Talk to @userinfobot on Telegram to find yours.
TELEGRAM_CHAT_ID=987654321

# ── YouTube ────────────────────────────────────
# Go to https://console.cloud.google.com
# → Create project → Enable "YouTube Data API v3" → Create API key
YOUTUBE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Instagram ──────────────────────────────────
# Burner account required to see public feeds
INSTAGRAM_USERNAME=burner_account
INSTAGRAM_PASSWORD=SuperSecretPass!
